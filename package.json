{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "php artisan generate:build-options && vite build && vite build --ssr",
        "build:ssr": "php artisan generate:build-options && vite build && vite build --ssr",
        "dev": "php artisan generate:build-options && vite",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "types:check": "vue-tsc --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.5",
        "@intlify/unplugin-vue-i18n": "^11.2.4",
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
