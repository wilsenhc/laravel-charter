        "chart.js": "^4.5.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "concurrently": "^9.2.4",
        "laravel-vite-plugin": "^3.1.3",
        "reka-ui": "^2.10.1",
        "shadcn-vue": "^2.8.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.3",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "vite": "^8.1.5",
        "vue": "^3.5.40",
        "vue-chartjs": "^5.3.4",
        "vue-i18n": "^11.4.7"
